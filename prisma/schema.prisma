generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String
  technologies   String[]
  github         String
  live           String?
  imageUrl       String?   // Add this for Cloudinary image URL
  imagePublicId  String?   // Add this to track image for deletion
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id      String   @id @default(cuid())
  name    String
  email   String
  message String
  isRead  Boolean  @default(false)
  sentAt  DateTime @default(now())
}

// ============================================
// NEW: Skill model for dynamic skills management
// ============================================
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique        // Must be unique (e.g., "React", "TypeScript")
  level     Int      @default(80)   // Percentage 0-100
  category  String   @default("technical")  // technical, soft, tools
  order     Int      @default(0)    // For sorting
  isVisible Boolean  @default(true) // Show/hide on website
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NEW: Hero Section Settings
model HeroSetting {
  id            String   @id @default(cuid())
  greeting      String   @default("Hi, I'm")
  name          String   @default("Ashpak Shaikh")
  titleLines    String[] @default(["Full Stack Developer", "Next.js Developer", "Node.js Backend Engineer"])
  description   String   @default("I build scalable applications using modern technologies.")
  primaryBtnText String  @default("View My Work")
  secondaryBtnText String @default("Contact Me")
  updatedAt     DateTime @updatedAt
}

// NEW: About Section
model AboutSetting {
  id          String   @id @default(cuid())
  bio         String   @db.Text
  stats       Json     // Stores array of {value, label, icon}
  updatedAt   DateTime @updatedAt
}

// NEW: Social Link
model SocialLink {
  id        String   @id @default(cuid())
  platform  String   @unique
  url       String
  icon      String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NEW: Site Setting
model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("text")
  category    String   @default("general")
  updatedAt   DateTime @updatedAt
}

// NEW: Testimonial
model Testimonial {
  id          String   @id @default(cuid())
  name        String
  company     String?
  position    String?
  content     String   @db.Text
  rating      Int      @default(5)
  imageUrl    String?
  imagePublicId String?
  isVisible   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}